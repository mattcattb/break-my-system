POSTGRES_DB=break_my_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=15432
REDIS_PORT=26379
DATABASE_URL=postgresql://postgres:postgres@localhost:15432/break_my_system
REDIS_URL=redis://localhost:26379
BETTER_AUTH_SECRET=dev-secret-change-me-32-characters
BETTER_AUTH_URL=http://localhost:5173

# The browser uses same-origin /api and /ws, forwarded by Vite to this target.
# API_PROXY_TARGET=http://localhost:3000
# Set VITE_API_URL and VITE_WS_URL only when deploying without the proxy.
# VITE_API_URL=https://api.example.com
# VITE_WS_URL=wss://api.example.com

# Required only when the web and API are served from separate origins.
# CORS_ORIGINS=https://app.example.com
# LOG_LEVEL=info
