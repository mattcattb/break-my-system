POSTGRES_DB=break_my_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=15432
REDIS_PORT=26379
WAD_HOST=127.0.0.1
WAD_PORT=27373
WAD_DATA_DIR=/tmp/break-my-system/wads
# Path inside the Minesweeper container's persistent /data volume.
MINESWEEPER_LEADERBOARD_PATH=/data/leaderboard.csv
DATABASE_URL=postgresql://postgres:postgres@localhost:15432/break_my_system
REDIS_URL=redis://localhost:26379
# PLC runtime TCP address.
PLC_HOST=127.0.0.1
PLC_PORT=7474
BETTER_AUTH_SECRET=dev-secret-change-me-32-characters
BETTER_AUTH_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000
# Optional. Leave empty to use same-origin /ws through the Vite dev proxy.
# VITE_WS_URL=ws://localhost:3000

# Optional
# CORS_ORIGINS=http://localhost:5173
# LOG_LEVEL=info
