    {"id":"phase1-box","type":"rectangle","x":1460,"y":910,"width":350,"height":300,"angle":0,"strokeColor":"#2563eb","backgroundColor":"#eff6ff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"e4","roundness":{"type":3},"seed":125,"version":1,"versionNonce":125,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false},
    {"id":"phase1-text","type":"text","x":1485,"y":935,"width":300,"height":245,"angle":0,"strokeColor":"#1e3a8a","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"e5","roundness":null,"seed":126,"version":1,"versionNonce":126,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"1 — MESSAGE CONTRACT\nws.messages.ts\n\nZod discriminated unions:\nterminal.attach / detach\nredis.command\nplc.request\nping\n\nCommon envelope:\nrequestId?\nterminalId?\npayload?\n\nServer events add sequence.\nKeep schemas beside exported\ninferred message types.","fontSize":17,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"1 — MESSAGE CONTRACT\nws.messages.ts\n\nZod discriminated unions:\nterminal.attach / detach\nredis.command\nplc.request\nping\n\nCommon envelope:\nrequestId?\nterminalId?\npayload?\n\nServer events add sequence.\nKeep schemas beside exported\ninferred message types.","autoResize":true,"lineHeight":1.25},
    {"id":"phase2-box","type":"rectangle","x":1845,"y":910,"width":350,"height":300,"angle":0,"strokeColor":"#7c3aed","backgroundColor":"#f5f3ff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"e6","roundness":{"type":3},"seed":127,"version":1,"versionNonce":127,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false},
    {"id":"phase2-text","type":"text","x":1870,"y":935,"width":300,"height":245,"angle":0,"strokeColor":"#5b21b6","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"e7","roundness":null,"seed":128,"version":1,"versionNonce":128,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"2 — TRANSPORT + ROUTER\nws.controller.ts\nws.router.ts\n\nController owns open/message/\nclose/error only.\n\nRouter is a small Map:\nrouter.on(type, handler)\nrouter.dispatch(ws, message)\n\nParse once before routing.\nOne error boundary sends a\ntyped terminal.error.\nNo metrics/auth framework yet.","fontSize":17,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"2 — TRANSPORT + ROUTER\nws.controller.ts\nws.router.ts\n\nController owns open/message/\nclose/error only.\n\nRouter is a small Map:\nrouter.on(type, handler)\nrouter.dispatch(ws, message)\n\nParse once before routing.\nOne error boundary sends a\ntyped terminal.error.\nNo metrics/auth framework yet.","autoResize":true,"lineHeight":1.25},
    {"id":"phase3-box","type":"rectangle","x":2230,"y":910,"width":350,"height":300,"angle":0,"strokeColor":"#d97706","backgroundColor":"#fffbeb","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"e8","roundness":{"type":3},"seed":129,"version":1,"versionNonce":129,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false},
    {"id":"phase3-text","type":"text","x":2255,"y":935,"width":300,"height":245,"angle":0,"strokeColor":"#92400e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"e9","roundness":null,"seed":130,"version":1,"versionNonce":130,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"3 — DOMAIN HANDLERS\nterminal.handler.ts\nredis.handler.ts\nplc.handler.ts (later)\n\nShared gate stays local:\nrequire terminal in sandbox\nrequire socket attachment\nrequire connection kind\n\nHandlers call the existing\nConnectionRegistry directly.\nDo not add service wrappers\nthat only rename calls.","fontSize":17,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"3 — DOMAIN HANDLERS\nterminal.handler.ts\nredis.handler.ts\nplc.handler.ts (later)\n\nShared gate stays local:\nrequire terminal in sandbox\nrequire socket attachment\nrequire connection kind\n\nHandlers call the existing\nConnectionRegistry directly.\nDo not add service wrappers\nthat only rename calls.","autoResize":true,"lineHeight":1.25},
    {"id":"phase4-box","type":"rectangle","x":2615,"y":910,"width":385,"height":300,"angle":0,"strokeColor":"#059669","backgroundColor":"#ecfdf5","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"f0","roundness":{"type":3},"seed":131,"version":1,"versionNonce":131,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false},
    {"id":"phase4-text","type":"text","x":2640,"y":935,"width":335,"height":245,"angle":0,"strokeColor":"#065f46","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"f1","roundness":null,"seed":132,"version":1,"versionNonce":132,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"4 — EVENTS + RECONNECT\nterminal.publisher.ts\n\nBun topic: terminal:{terminalId}\nSocket subscribes after ownership gate.\n\nClient callback → append event →\nsequence++ → publish topic.\n\nReconnect sends afterSequence;\nserver replays bounded history, then\ncontinues live delivery.\n\nSocket close detaches only.\nTerminal close / sandbox TTL closes\nthe Redis or PLC client.","fontSize":17,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"4 — EVENTS + RECONNECT\nterminal.publisher.ts\n\nBun topic: terminal:{terminalId}\nSocket subscribes after ownership gate.\n\nClient callback → append event →\nsequence++ → publish topic.\n\nReconnect sends afterSequence;\nserver replays bounded history, then\ncontinues live delivery.\n\nSocket close detaches only.\nTerminal close / sandbox TTL closes\nthe Redis or PLC client.","autoResize":true,"lineHeight":1.25},
    {"id":"build-order","type":"text","x":1510,"y":1250,"width":1420,"height":30,"angle":0,"strokeColor":"#334155","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"f2","roundness":null,"seed":133,"version":1,"versionNonce":133,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"Implement in order: message schemas → attach + ping → Redis command → terminal events → SUBSCRIBE → replay → PLC only when its protocol is real.","fontSize":18,"fontFamily":2,"textAlign":"center","verticalAlign":"top","containerId":null,"originalText":"Implement in order: message schemas → attach + ping → Redis command → terminal events → SUBSCRIBE → replay → PLC only when its protocol is real.","autoResize":true,"lineHeight":1.25},
