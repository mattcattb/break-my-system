    {"id":"events-attach-box","type":"rectangle","x":3380,"y":2340,"width":370,"height":370,"angle":0,"strokeColor":"#7048e8","backgroundColor":"#e5dbff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"n7","roundness":{"type":3},"seed":268,"version":1,"versionNonce":268,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false},
    {"id":"events-attach-text","type":"text","x":3405,"y":2365,"width":320,"height":315,"angle":0,"strokeColor":"#5f3dc4","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"n8","roundness":null,"seed":269,"version":1,"versionNonce":269,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"GENERIC TOOL ATTACHMENT\nWebSocket delivery concern\n\nClient\ntool.attach\n{ toolId, requestId,\n  afterSequence? }\n\nServer\n• require tool in socket sandbox\n• subscribe tool:{toolId}\n• remember attachedToolIds\n• replay tool events if supported\n• send tool.attached\n\nAttachment does not connect or disconnect Redis.","fontSize":16,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"GENERIC TOOL ATTACHMENT\nWebSocket delivery concern\n\nClient\ntool.attach\n{ toolId, requestId,\n  afterSequence? }\n\nServer\n• require tool in socket sandbox\n• subscribe tool:{toolId}\n• remember attachedToolIds\n• replay tool events if supported\n• send tool.attached\n\nAttachment does not connect or disconnect Redis.","autoResize":true,"lineHeight":1.25},
    {"id":"events-direct-box","type":"rectangle","x":3800,"y":2340,"width":390,"height":370,"angle":0,"strokeColor":"#1971c2","backgroundColor":"#d0ebff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"n9","roundness":{"type":3},"seed":270,"version":1,"versionNonce":270,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false},
    {"id":"events-direct-text","type":"text","x":3825,"y":2365,"width":340,"height":315,"angle":0,"strokeColor":"#0b5394","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"o0","roundness":null,"seed":271,"version":1,"versionNonce":271,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"DIRECT REQUEST / RESPONSE\nCorrelated by requestId; not replayed\n\nTerminal\nterminal.command\n→ terminal.command.accepted | error\n\nKey Explorer queries\nPrefer REST/Hono RPC:\n• scan\n• inspect\n\nIf WS is truly needed:\nkv.scan.request → kv.scan.result\nkv.inspect.request → kv.inspect.result\n\nDo not add sequence to ordinary query responses.","fontSize":16,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"DIRECT REQUEST / RESPONSE\nCorrelated by requestId; not replayed\n\nTerminal\nterminal.command\n→ terminal.command.accepted | error\n\nKey Explorer queries\nPrefer REST/Hono RPC:\n• scan\n• inspect\n\nIf WS is truly needed:\nkv.scan.request → kv.scan.result\nkv.inspect.request → kv.inspect.result\n\nDo not add sequence to ordinary query responses.","autoResize":true,"lineHeight":1.25},
    {"id":"events-stream-box","type":"rectangle","x":4240,"y":2340,"width":400,"height":370,"angle":0,"strokeColor":"#2b8a3e","backgroundColor":"#d3f9d8","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"o1","roundness":{"type":3},"seed":272,"version":1,"versionNonce":272,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false},
    {"id":"events-stream-text","type":"text","x":4265,"y":2365,"width":350,"height":315,"angle":0,"strokeColor":"#1b5e20","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"o2","roundness":null,"seed":273,"version":1,"versionNonce":273,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"REPLAYABLE TOOL EVENT\nBroadcast to every attached socket\n\nCommon event fields\n• type\n• toolId\n• sequence\n• occurredAt\n• payload\n• causationRequestId?\n\nOwned by the tool stream:\nappend → assign sequence → retain bounded history → publish tool:{id}\n\nClient deduplicates and detects gaps per toolId.","fontSize":16,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"REPLAYABLE TOOL EVENT\nBroadcast to every attached socket\n\nCommon event fields\n• type\n• toolId\n• sequence\n• occurredAt\n• payload\n• causationRequestId?\n\nOwned by the tool stream:\nappend → assign sequence → retain bounded history → publish tool:{id}\n\nClient deduplicates and detects gaps per toolId.","autoResize":true,"lineHeight":1.25},
    {"id":"events-domain-box","type":"rectangle","x":4690,"y":2340,"width":380,"height":370,"angle":0,"strokeColor":"#e67700","backgroundColor":"#fff3bf","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"o3","roundness":{"type":3},"seed":274,"version":1,"versionNonce":274,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false},
    {"id":"events-domain-text","type":"text","x":4715,"y":2365,"width":330,"height":315,"angle":0,"strokeColor":"#9a4d00","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"o4","roundness":null,"seed":275,"version":1,"versionNonce":275,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"NAMESPACED DOMAIN EVENTS\nOnly add events for real pushes\n\nTerminal\n• terminal.output.appended\n• terminal.execution.completed\n• terminal.execution.failed\n\nKV Explorer (only if watching)\n• kv.key.changed\n• kv.key.expired\n• kv.scan.invalidated\n\nPLC later\n• plc.value.changed\n• plc.alarm.raised\n\nAvoid generic execute.result payloads.","fontSize":16,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"NAMESPACED DOMAIN EVENTS\nOnly add events for real pushes\n\nTerminal\n• terminal.output.appended\n• terminal.execution.completed\n• terminal.execution.failed\n\nKV Explorer (only if watching)\n• kv.key.changed\n• kv.key.expired\n• kv.scan.invalidated\n\nPLC later\n• plc.value.changed\n• plc.alarm.raised\n\nAvoid generic execute.result payloads.","autoResize":true,"lineHeight":1.25},
