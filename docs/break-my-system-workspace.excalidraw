    {"id":"current-sandbox-text","type":"text","x":3405,"y":245,"width":250,"height":265,"angle":0,"strokeColor":"#1b5e20","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"h5","roundness":null,"seed":206,"version":1,"versionNonce":206,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"SANDBOX\nsandbox.ts + runtime.ts\n\nState\n• id / timestamps\n• Map<toolId, Tool>\n• Set<connectionId>\n\nOwns\n• tool membership\n• sandbox TTL cleanup\n• closeMany(connectionIds)\n\nDoes not execute Redis commands.","fontSize":16,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"SANDBOX\nsandbox.ts + runtime.ts\n\nState\n• id / timestamps\n• Map<toolId, Tool>\n• Set<connectionId>\n\nOwns\n• tool membership\n• sandbox TTL cleanup\n• closeMany(connectionIds)\n\nDoes not execute Redis commands.","autoResize":true,"lineHeight":1.25},
