    {"id":"browser-box","type":"rectangle","x":1470,"y":180,"width":275,"height":495,"angle":0,"strokeColor":"#2563eb","backgroundColor":"#eff6ff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"c3","roundness":{"type":3},"seed":104,"version":1,"versionNonce":104,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false},
    {"id":"browser-text","type":"text","x":1495,"y":205,"width":225,"height":420,"angle":0,"strokeColor":"#1e3a8a","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"c4","roundness":null,"seed":105,"version":1,"versionNonce":105,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"BROWSER PAGE\n\n1 WebSocket / sandbox\n\nAttached terminals\n• redis terminal A\n• redis terminal B\n• PLC terminal C\n\nSends\nterminal.attach\nredis.command\nplc.request\n\nReceives\ncommand results\npub/sub messages\nPLC updates\nstatus + replay\n\nReact Query keeps\nsnapshots; socket feeds\nlive terminal events.","fontSize":17,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"BROWSER PAGE\n\n1 WebSocket / sandbox\n\nAttached terminals\n• redis terminal A\n• redis terminal B\n• PLC terminal C\n\nSends\nterminal.attach\nredis.command\nplc.request\n\nReceives\ncommand results\npub/sub messages\nPLC updates\nstatus + replay\n\nReact Query keeps\nsnapshots; socket feeds\nlive terminal events.","autoResize":true,"lineHeight":1.25},
    {"id":"transport-box","type":"rectangle","x":1830,"y":180,"width":300,"height":495,"angle":0,"strokeColor":"#7c3aed","backgroundColor":"#f5f3ff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"c5","roundness":{"type":3},"seed":106,"version":1,"versionNonce":106,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false},
    {"id":"transport-text","type":"text","x":1855,"y":205,"width":250,"height":420,"angle":0,"strokeColor":"#5b21b6","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"c6","roundness":null,"seed":107,"version":1,"versionNonce":107,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"WS TRANSPORT\nws.controller.ts\n\nOnly lifecycle work\n• open / close\n• decode JSON\n• validate union\n• router.dispatch\n• serialize errors\n\nSocket context stores\n• socketId\n• sandboxId\n• attached terminalIds\n• optional userId\n\nNever stores a live\nRedis or PLC client.\n\nOn reconnect:\nattach(afterSequence)","fontSize":17,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"WS TRANSPORT\nws.controller.ts\n\nOnly lifecycle work\n• open / close\n• decode JSON\n• validate union\n• router.dispatch\n• serialize errors\n\nSocket context stores\n• socketId\n• sandboxId\n• attached terminalIds\n• optional userId\n\nNever stores a live\nRedis or PLC client.\n\nOn reconnect:\nattach(afterSequence)","autoResize":true,"lineHeight":1.25},
    {"id":"handlers-box","type":"rectangle","x":2215,"y":180,"width":350,"height":495,"angle":0,"strokeColor":"#d97706","backgroundColor":"#fffbeb","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"c7","roundness":{"type":3},"seed":108,"version":1,"versionNonce":108,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false},
    {"id":"handlers-text","type":"text","x":2240,"y":205,"width":300,"height":430,"angle":0,"strokeColor":"#92400e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"c8","roundness":null,"seed":109,"version":1,"versionNonce":109,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"TYPED HANDLERS\nsmall router: type → function\n\nterminal.handler.ts\n• attach / detach\n• validate sandbox ownership\n• replay events\n\nredis.handler.ts\n• command\n• subscribe / unsubscribe\n\nplc.handler.ts\n• read / write\n• subscribe to updates\n\nEvery handler receives\n{ ws, sandbox, message }\nthen resolves terminalId →\nconnectionId → typed client.\n\nGate by connection.kind;\nnever accept connectionId\nfrom the browser.","fontSize":17,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"TYPED HANDLERS\nsmall router: type → function\n\nterminal.handler.ts\n• attach / detach\n• validate sandbox ownership\n• replay events\n\nredis.handler.ts\n• command\n• subscribe / unsubscribe\n\nplc.handler.ts\n• read / write\n• subscribe to updates\n\nEvery handler receives\n{ ws, sandbox, message }\nthen resolves terminalId →\nconnectionId → typed client.\n\nGate by connection.kind;\nnever accept connectionId\nfrom the browser.","autoResize":true,"lineHeight":1.25},
    {"id":"runtime-box","type":"rectangle","x":2650,"y":180,"width":350,"height":350,"angle":0,"strokeColor":"#059669","backgroundColor":"#ecfdf5","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"c9","roundness":{"type":3},"seed":110,"version":1,"versionNonce":110,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false},
