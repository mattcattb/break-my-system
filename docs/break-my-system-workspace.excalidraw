    {"id":"events-rule","type":"text","x":3390,"y":2760,"width":2060,"height":135,"angle":0,"strokeColor":"#334155","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"p1","roundness":null,"seed":282,"version":1,"versionNonce":282,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"DECISION RULE\nUse REST/direct response when the caller asks for a finite answer. Attach a socket to a tool only when the tool can push ongoing shared changes.\nSequence only replayable tool events—not pongs, validation errors, attachment acknowledgements or ordinary KV scan/inspect results.\nKeep sandbox:{id} for sandbox lifecycle; use tool:{toolId} for authorized tool streams; do not expose connection:{id} until shared-connection events create a real need.","fontSize":18,"fontFamily":2,"textAlign":"center","verticalAlign":"top","containerId":null,"originalText":"DECISION RULE\nUse REST/direct response when the caller asks for a finite answer. Attach a socket to a tool only when the tool can push ongoing shared changes.\nSequence only replayable tool events—not pongs, validation errors, attachment acknowledgements or ordinary KV scan/inspect results.\nKeep sandbox:{id} for sandbox lifecycle; use tool:{toolId} for authorized tool streams; do not expose connection:{id} until shared-connection events create a real need.","autoResize":true,"lineHeight":1.25}
