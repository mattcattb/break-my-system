    {"id":"current-tool-text","type":"text","x":3755,"y":245,"width":250,"height":260,"angle":0,"strokeColor":"#9a4d00","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"h7","roundness":null,"seed":208,"version":1,"versionNonce":208,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"TOOL UNION\ntools/tool.ts\n\nTool =\n• CommandTerminalTool\n• KeyExplorerTool\n\nToolSnapshot =\n• terminal snapshot\n• explorer snapshot\n\ntoToolSnapshot() dispatches by tool.kind.","fontSize":16,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"TOOL UNION\ntools/tool.ts\n\nTool =\n• CommandTerminalTool\n• KeyExplorerTool\n\nToolSnapshot =\n• terminal snapshot\n• explorer snapshot\n\ntoToolSnapshot() dispatches by tool.kind.","autoResize":true,"lineHeight":1.25},
