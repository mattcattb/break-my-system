    {"id":"taxonomy-title","type":"text","x":1460,"y":1390,"width":920,"height":35,"angle":0,"strokeColor":"#111827","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"f4","roundness":null,"seed":135,"version":1,"versionNonce":135,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"Message taxonomy — generic transport, capability-based commands, typed system events","fontSize":24,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Message taxonomy — generic transport, capability-based commands, typed system events","autoResize":true,"lineHeight":1.25},
    {"id":"taxonomy-envelope","type":"rectangle","x":1460,"y":1455,"width":350,"height":285,"angle":0,"strokeColor":"#475569","backgroundColor":"#ffffff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"f5","roundness":{"type":3},"seed":136,"version":1,"versionNonce":136,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false},
    {"id":"taxonomy-envelope-text","type":"text","x":1485,"y":1480,"width":300,"height":230,"angle":0,"strokeColor":"#334155","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"f6","roundness":null,"seed":137,"version":1,"versionNonce":137,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"COMMON ENVELOPE\n\ntype — routing discriminator\nrequestId — request correlation\nterminalId — ownership lookup\npayload — inferred per type\n\nPersisted server events also add:\nsequence\noccurredAt\n\nDo not add system + action fields\nthat duplicate the type string.\nInfer TS types from Zod schemas.","fontSize":17,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"COMMON ENVELOPE\n\ntype — routing discriminator\nrequestId — request correlation\nterminalId — ownership lookup\npayload — inferred per type\n\nPersisted server events also add:\nsequence\noccurredAt\n\nDo not add system + action fields\nthat duplicate the type string.\nInfer TS types from Zod schemas.","autoResize":true,"lineHeight":1.25},
    {"id":"taxonomy-command","type":"rectangle","x":1845,"y":1455,"width":350,"height":285,"angle":0,"strokeColor":"#2563eb","backgroundColor":"#eff6ff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"f7","roundness":{"type":3},"seed":138,"version":1,"versionNonce":138,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false},
    {"id":"taxonomy-command-text","type":"text","x":1870,"y":1480,"width":300,"height":230,"angle":0,"strokeColor":"#1e3a8a","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"f8","roundness":null,"seed":139,"version":1,"versionNonce":139,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"GENERIC COMMAND — YES, IF…\n\nterminal.command\n{ terminalId, requestId,\n  payload: { input: string } }\n\nUse only for tools with a real\ntext-command capability. The terminal\nresolves its connection kind and the\nRedis / PLC implementation parses it.\n\nDo not force every future system into\nexecute(). Structured operations can\nstill be plc.write, redis.inspect, etc.","fontSize":17,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"GENERIC COMMAND — YES, IF…\n\nterminal.command\n{ terminalId, requestId,\n  payload: { input: string } }\n\nUse only for tools with a real\ntext-command capability. The terminal\nresolves its connection kind and the\nRedis / PLC implementation parses it.\n\nDo not force every future system into\nexecute(). Structured operations can\nstill be plc.write, redis.inspect, etc.","autoResize":true,"lineHeight":1.25},
    {"id":"taxonomy-events","type":"rectangle","x":2230,"y":1455,"width":350,"height":285,"angle":0,"strokeColor":"#059669","backgroundColor":"#ecfdf5","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"f9","roundness":{"type":3},"seed":140,"version":1,"versionNonce":140,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false},
    {"id":"taxonomy-events-text","type":"text","x":2255,"y":1480,"width":300,"height":230,"angle":0,"strokeColor":"#065f46","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"g0","roundness":null,"seed":141,"version":1,"versionNonce":141,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"SERVER EVENT UNION\n\nGeneric lifecycle\nterminal.attached\nterminal.command.result\nconnection.status.changed\nterminal.error\n\nSystem-specific pushes\nredis.pubsub.message\nredis.monitor.message\nplc.value.changed\nplc.alarm.raised\n\nKeep payloads typed so future UI\ncan render more than plain lines.","fontSize":17,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"SERVER EVENT UNION\n\nGeneric lifecycle\nterminal.attached\nterminal.command.result\nconnection.status.changed\nterminal.error\n\nSystem-specific pushes\nredis.pubsub.message\nredis.monitor.message\nplc.value.changed\nplc.alarm.raised\n\nKeep payloads typed so future UI\ncan render more than plain lines.","autoResize":true,"lineHeight":1.25},
    {"id":"taxonomy-expand","type":"rectangle","x":2615,"y":1455,"width":385,"height":285,"angle":0,"strokeColor":"#d97706","backgroundColor":"#fffbeb","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"g1","roundness":{"type":3},"seed":142,"version":1,"versionNonce":142,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false},
    {"id":"taxonomy-expand-text","type":"text","x":2640,"y":1480,"width":335,"height":230,"angle":0,"strokeColor":"#92400e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"index":"g2","roundness":null,"seed":143,"version":1,"versionNonce":143,"isDeleted":false,"boundElements":null,"updated":0,"link":null,"locked":false,"text":"EXPANSION RULE\n\nStart with one ws.messages.ts.\nSplit only when a real system arrives:\nmessages/terminal.ts\nmessages/redis.ts\nmessages/plc.ts\nmessages/index.ts builds unions\n\nHandlers mirror those domains.\nNo FooPayload / FooResponse types:\nuse z.infer and Extract<Message,\n{ type: T }>.\n\nNew system = schemas + handler +\nconnection implementation; transport\ndoes not change.","fontSize":17,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"EXPANSION RULE\n\nStart with one ws.messages.ts.\nSplit only when a real system arrives:\nmessages/terminal.ts\nmessages/redis.ts\nmessages/plc.ts\nmessages/index.ts builds unions\n\nHandlers mirror those domains.\nNo FooPayload / FooResponse types:\nuse z.infer and Extract<Message,\n{ type: T }>.\n\nNew system = schemas + handler +\nconnection implementation; transport\ndoes not change.","autoResize":true,"lineHeight":1.25},
